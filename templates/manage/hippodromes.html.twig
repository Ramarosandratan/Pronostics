{% extends 'manage/base.html.twig' %}

{% block title %}Gestion - Hippodromes{% endblock %}

{% block body %}
    <section class="card">
        <h1>Hippodromes</h1>
        <form method="post">
            <label for="name">Nom</label>
            <input id="name" name="name" type="text" required maxlength="255" placeholder="Ex: VINCENNES" />
            <button type="submit">Ajouter</button>
        </form>
    </section>

    <section class="card">
        <h2>Liste</h2>
        <form method="get" class="inline-form" style="margin-bottom: 12px;">
            <label for="per_page_hippodromes">Par page</label>
            <select id="per_page_hippodromes" name="per_page" onchange="this.form.submit()">
                {% for option in perPageOptions %}
                    <option value="{{ option }}" {% if option == perPage %}selected{% endif %}>{{ option }}</option>
                {% endfor %}
            </select>
        </form>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for hippodrome in hippodromes %}
                    <tr>
                        <td>{{ hippodrome.id }}</td>
                        {% if editHippodrome and editHippodrome.id == hippodrome.id %}
                            <td>
                                <input name="name" type="text" value="{{ hippodrome.name }}" required maxlength="255" form="hippodrome-edit-{{ hippodrome.id }}" />
                            </td>
                            <td>
                                <form id="hippodrome-edit-{{ hippodrome.id }}" method="post" action="{{ path('app_management_hippodrome_update', { id: hippodrome.id }) }}" class="inline-form" style="margin: 0;">
                                    <input type="hidden" name="page" value="{{ pagination.page }}" />
                                    <input type="hidden" name="per_page" value="{{ perPage }}" />
                                    <button type="submit">Enregistrer</button>
                                    <a href="{{ path('app_management_hippodromes', { page: pagination.page, per_page: perPage }) }}">Annuler</a>
                                </form>
                            </td>
                        {% else %}
                            <td>{{ hippodrome.name }}</td>
                            <td>
                                <div class="inline-form">
                                    <form method="get" action="{{ path('app_management_hippodromes') }}" class="inline-form" style="margin: 0;">
                                        <input type="hidden" name="edit" value="{{ hippodrome.id }}" />
                                        <input type="hidden" name="page" value="{{ pagination.page }}" />
                                        <input type="hidden" name="per_page" value="{{ perPage }}" />
                                        <button type="submit">Modifier</button>
                                    </form>
                                    <form method="post" action="{{ path('app_management_hippodrome_delete', { id: hippodrome.id }) }}" class="inline-form" style="margin: 0;">
                                        <button type="submit">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        {% endif %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">Aucun hippodrome enregistre.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        {% if pagination.total_pages > 1 %}
            <div class="inline-form" style="margin-top: 12px; justify-content: space-between;">
                <div>
                    {% if pagination.has_prev %}
                        <a href="{{ path('app_management_hippodromes', { page: pagination.prev_page, per_page: perPage }) }}">Precedent</a>
                    {% endif %}
                </div>
                <div class="muted">Page {{ pagination.page }} / {{ pagination.total_pages }} - {{ pagination.total_items }} elements</div>
                <div>
                    {% if pagination.has_next %}
                        <a href="{{ path('app_management_hippodromes', { page: pagination.next_page, per_page: perPage }) }}">Suivant</a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </section>
{% endblock %}
