{% extends 'manage/base.html.twig' %}

{% block title %}Gestion - Pronostic course{% endblock %}

{% block body %}
    <style>
        .confidence-wrap {
            margin-top: 12px;
            padding: 12px;
            border: 1px solid var(--line);
            border-radius: 10px;
            background: #f8fbff;
        }
        .confidence-head {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 10px;
            margin-bottom: 8px;
        }
        .confidence-percent {
            font-size: 1.1rem;
            font-weight: 700;
        }
        .confidence-meter {
            width: 100%;
            height: 10px;
            border-radius: 999px;
            background: #e8eef8;
            overflow: hidden;
            margin-bottom: 8px;
        }
        .confidence-meter-fill {
            height: 100%;
            background: linear-gradient(90deg, #e57a13 0%, #0d66d0 55%, #0e7a45 100%);
        }
        .stars {
            letter-spacing: 1px;
            font-weight: 700;
        }
    </style>

    <section class="card">
        <h1>Pronostic course #{{ race.id }}</h1>
        <p class="muted">
            {{ race.hippodrome ? race.hippodrome.name : '-' }} - R{{ race.meetingNumber }} C{{ race.raceNumber }}
            {% if race.raceDate %}
                - {{ race.raceDate|date('Y-m-d') }}
            {% endif %}
            {% if race.discipline %}
                - {{ race.discipline }}
            {% endif %}
        </p>
        <p>
            Endpoint JSON:
            <a href="{{ path('app_pronostic_show', {id: race.id, mode: scoringMode}) }}">{{ path('app_pronostic_show', {id: race.id, mode: scoringMode}) }}</a>
        </p>
        <p class="muted">Mode actif: {{ scoringMode }}</p>
        <p>
            <a href="{{ path('app_management_race_pronostic', {id: race.id, mode: 'conservative'}) }}">Mode conservateur</a>
            |
            <a href="{{ path('app_management_race_pronostic', {id: race.id, mode: 'aggressive'}) }}">Mode agressif</a>
            |
            <a href="{{ path('app_management_race_pronostic_export', {id: race.id, mode: scoringMode}) }}">Exporter CSV</a>
        </p>

        <div class="confidence-wrap">
            <div class="confidence-head">
                <strong>Indice de confiance (course)</strong>
                <span class="confidence-percent">{{ confidence.percent|number_format(1, '.', ' ') }}% - {{ confidence.label }}</span>
            </div>
            <div class="confidence-meter" aria-label="Indice de confiance {{ confidence.percent|number_format(1, '.', ' ') }} pour cent">
                <div class="confidence-meter-fill" style="width: {{ confidence.percent }}%;"></div>
            </div>
            <p class="muted" style="margin: 0;">
                <span class="stars">
                    {% for i in 1..5 %}
                        {% if i <= confidence.stars %}★{% else %}☆{% endif %}
                    {% endfor %}
                </span>
                {{ confidence.reason }}
            </p>
        </div>
    </section>

    <section class="card">
        <h2>Top 5 chevaux</h2>
        <table>
            <thead>
                <tr>
                    <th>Rang</th>
                    <th>Cheval</th>
                    <th>N degre</th>
                    <th>Probabilite victoire</th>
                    <th>Score global</th>
                </tr>
            </thead>
            <tbody>
                {% for row in topRankings %}
                    <tr>
                        <td>{{ row.rank }}</td>
                        <td>{{ row.horse_name }}</td>
                        <td>{{ row.saddle_number ?: '-' }}</td>
                        <td>{{ row.win_probability|number_format(1, '.', ' ') }}%</td>
                        <td>{{ row.score|number_format(2, '.', ' ') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucune participation disponible pour cette course.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Pourquoi ce classement</h2>
        <table>
            <thead>
                <tr>
                    <th>Rang</th>
                    <th>Cheval</th>
                    <th>Probabilite</th>
                    <th>Explication</th>
                </tr>
            </thead>
            <tbody>
                {% for item in topExplanations %}
                    <tr>
                        <td>{{ item.rank }}</td>
                        <td>{{ item.horse_name }}{% if item.saddle_number %} (#{{ item.saddle_number }}){% endif %}</td>
                        <td>{{ item.win_probability|number_format(1, '.', ' ') }}%</td>
                        <td>{{ item.text }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">Aucune explication disponible pour cette course.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Detail des sous-scores</h2>
        <table>
            <thead>
                <tr>
                    <th>Rang</th>
                    <th>Cheval</th>
                    <th>Position ({{ scoringWeights.position|number_format(1, '.', ' ') }}%)</th>
                    <th>Cote ({{ scoringWeights.odds|number_format(1, '.', ' ') }}%)</th>
                    <th>Performance ({{ scoringWeights.performance|number_format(1, '.', ' ') }}%)</th>
                    <th>Gains ({{ scoringWeights.earnings|number_format(1, '.', ' ') }}%)</th>
                    <th>Age ({{ scoringWeights.age|number_format(1, '.', ' ') }}%)</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                {% for row in rankings %}
                    <tr>
                        <td>{{ row.rank }}</td>
                        <td>{{ row.horse_name }}</td>
                        <td>{{ row.sub_scores.position|number_format(2, '.', ' ') }}</td>
                        <td>{{ row.sub_scores.odds|number_format(2, '.', ' ') }}</td>
                        <td>{{ row.sub_scores.performance|number_format(2, '.', ' ') }}</td>
                        <td>{{ row.sub_scores.earnings|number_format(2, '.', ' ') }}</td>
                        <td>{{ row.sub_scores.age|number_format(2, '.', ' ') }}</td>
                        <td><strong>{{ row.score|number_format(2, '.', ' ') }}</strong></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8">Aucune participation disponible pour cette course.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
