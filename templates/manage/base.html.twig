<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{% block title %}Gestion des donnees{% endblock %}</title>
        <style>
            :root {
                --bg: #f4f6fb;
                --surface: #ffffff;
                --line: #dfe5f0;
                --text: #192230;
                --accent: #0d66d0;
                --ok: #0e7a45;
                --error: #a32121;
            }
            * { box-sizing: border-box; }
            body {
                margin: 0;
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(180deg, #eef3ff 0%, var(--bg) 100%);
                color: var(--text);
                margin-left: 280px;
            }
            .navbar {
                position: fixed;
                top: 0;
                left: 0;
                width: 280px;
                height: 100vh;
                background: var(--surface);
                border-right: 2px solid var(--line);
                z-index: 1000;
                display: flex;
                flex-direction: column;
                padding: 0;
                box-shadow: 2px 0 8px rgba(0, 0, 0, 0.08);
                overflow-y: auto;
            }
            .navbar-brand {
                font-weight: 700;
                font-size: 1.3rem;
                color: var(--accent);
                text-decoration: none;
                padding: 20px;
                border-bottom: 2px solid var(--line);
                display: block;
                text-align: center;
                white-space: nowrap;
            }
            .navbar-links {
                display: flex;
                flex-direction: column;
                gap: 0;
                flex: 1;
                list-style: none;
                margin: 0;
                padding: 0;
            }
            .navbar-group {
                display: flex;
                flex-direction: column;
                gap: 0;
                border-bottom: 1px solid var(--line);
                padding: 10px 0;
            }
            .navbar-group:last-child {
                border-bottom: none;
            }
            .navbar-link {
                text-decoration: none;
                color: var(--text);
                font-weight: 500;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                transition: color 0.2s ease, background 0.2s ease;
                position: relative;
            }
            .navbar-link:hover {
                color: var(--accent);
                background: #f0f5ff;
            }
            .navbar-link::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 4px;
                background: var(--accent);
                opacity: 0;
                transition: opacity 0.2s ease;
            }
            .navbar-link:hover::before {
                opacity: 1;
            }
            .container {
                max-width: 1100px;
                margin: 0 auto;
                padding: 20px;
            }
            .card {
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: 12px;
                padding: 16px;
                margin-bottom: 16px;
            }
            h1, h2 {
                margin-top: 0;
            }
            table {
                width: 100%;
                border-collapse: collapse;
            }
            th, td {
                border-bottom: 1px solid var(--line);
                padding: 8px;
                text-align: left;
                vertical-align: top;
            }
            form {
                display: grid;
                gap: 10px;
            }
            .inline-form {
                display: flex;
                gap: 8px;
                align-items: center;
            }
            input, select, button {
                padding: 10px;
                border-radius: 8px;
                border: 1px solid #c4cedf;
                font: inherit;
            }
            button {
                width: fit-content;
                background: var(--accent);
                color: #fff;
                border: none;
                cursor: pointer;
                font-weight: 600;
            }
            .flash {
                padding: 10px;
                border-radius: 8px;
                margin-bottom: 10px;
            }
            .flash.success {
                background: #e3f7ed;
                color: var(--ok);
            }
            .flash.error {
                background: #fde9e9;
                color: var(--error);
            }
            .stats {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                gap: 12px;
            }
            .stat {
                border: 1px solid var(--line);
                border-radius: 10px;
                padding: 12px;
                background: #fafcff;
            }
            a.stat {
                text-decoration: none;
                color: var(--text);
                transition: border-color 0.2s ease, transform 0.2s ease;
            }
            a.stat:hover {
                border-color: var(--accent);
                transform: translateY(-1px);
            }
            .muted {
                color: #4a5d78;
            }
        </style>
    </head>
    <body>
        <nav class="navbar">
            <a href="{{ path('app_management_index') }}" class="navbar-brand">📊 Pronostics</a>
            <ul class="navbar-links">
                <div class="navbar-group">
                    <a href="{{ path('app_home') }}" class="navbar-link">🏠 Accueil</a>
                </div>
                <div class="navbar-group">
                    <a href="{{ path('app_management_people') }}" class="navbar-link">👤 Personnes</a>
                    <a href="{{ path('app_management_horses') }}" class="navbar-link">🐴 Chevaux</a>
                    <a href="{{ path('app_management_races') }}" class="navbar-link">🏁 Courses</a>
                    <a href="{{ path('app_management_participations') }}" class="navbar-link">📝 Participations</a>
                    <a href="{{ path('app_management_hippodromes') }}" class="navbar-link">🏇 Hippodromes</a>
                </div>
                <div class="navbar-group">
                    <a href="{{ path('app_management_import_sessions') }}" class="navbar-link">📥 Imports</a>
                    <a href="{{ path('app_management_normalization') }}" class="navbar-link">✓ Normalisation</a>
                    <a href="{{ path('app_management_dashboard') }}" class="navbar-link">📈 Dashboard KPI</a>
                </div>
            </ul>
        </nav>

        <div class="container">

            {% for message in app.flashes('success') %}
                <div class="flash success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash error">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </div>
    </body>
</html>
